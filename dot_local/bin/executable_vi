#! /usr/bin/env nu

def main [...rest] {
  let nvim_12 = which -a nvim
  | insert minor { |install|
    ^$install.path --version
    | lines
    | first
    | parse 'NVIM v{major}.{minor}.{patch}'
    | get minor
  }
  | flatten
  | where minor == '12'
  | first
  | get path

  if ($nvim_12 | is-not-empty) {
    $env.NVIM_APPNAME = 'nvim-pack'
    ^$nvim_12 ...$rest
  } else {
    ^nvim ...$rest
  }
}

