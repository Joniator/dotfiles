# Ignore everything by default
/*
/.*

# Ignore compiled zsh files and completion
.zcompdump*
*.zwc
.config/zsh/plugins.zsh

# Don't ignore config relevant files and directories
!/.gitignore
!/.gitconfig
!/.gitmodules
!/.zshenv

!/.config
/.config/sdkman
/.config/gnupg
/.config/secrets
/.config/vim/viminfo
